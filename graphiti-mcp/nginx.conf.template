# nginx-Proxy vor dem Graphiti-MCP-Server.
# Zweck: Der MCP-Endpunkt ist nur unter einem Geheimpfad erreichbar
# (claude.ai-Custom-Connector kann keine Auth-Header senden).
# ${LISTEN_PORT} und ${MCP_PATH_SECRET} werden in start.sh per envsubst ersetzt.

worker_processes 1;
error_log /dev/stderr warn;
pid /tmp/nginx.pid;

events {
  worker_connections 256;
}

http {
  access_log off;
  client_max_body_size 20m;

  server {
    listen ${LISTEN_PORT};

    # Health-Check ohne Geheimpfad (verraet nichts, hilft beim Debuggen)
    location = /health {
      proxy_pass http://127.0.0.1:8000/health;
    }

    # MCP nur ueber den Geheimpfad: https://<service-url>/<SECRET>/mcp/
    location /${MCP_PATH_SECRET}/ {
      proxy_pass http://127.0.0.1:8000/;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header Connection "";
      # Streamable HTTP / SSE: nicht puffern, lange offen halten
      proxy_buffering off;
      proxy_cache off;
      proxy_read_timeout 3600s;
      proxy_send_timeout 3600s;
    }

    location / {
      return 404;
    }
  }
}
