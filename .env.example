# KI-Provider: "claude" (kostenpflichtig, Cloud) oder "ollama" (kostenlos, lokal)
AI_PROVIDER=ollama

# Ollama (nur wenn AI_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Anthropic/Claude (nur wenn AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Slack-Bot (Pflicht fuer Slack-Integration)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Optional
GENESIS_API_KEY=

# Mailer — SMTP-Versand. Server frei waehlbar (Gmail ODER IONOS o.a.).
#
# --- Variante A: IONOS (Versand als info@leanstech-gmbh.de) ---
#   MAIL_HOST=smtp.ionos.de
#   MAIL_PORT=587
#   MAIL_USER=info@leanstech-gmbh.de
#   MAIL_PASSWORD=<Postfach-Passwort des info@-Kontos>   # als Secret hinterlegen!
#   MAIL_FROM=info@leanstech-gmbh.de
#
# --- Variante B: Gmail (Standard, App-Passwort noetig) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
GMAIL_USER=leanstechgmbh@gmail.com
GMAIL_APP_PASSWORD=
# Absender im From-Header (leer lassen = Login-Adresse).
MAIL_FROM=info@leanstech-gmbh.de
MAIL_ABSENDER=Semir Redzic
MAIL_FIRMA=LeansTech GmbH
MAIL_WEBSITE=www.leanstech-klima.de
