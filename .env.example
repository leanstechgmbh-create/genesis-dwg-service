# KI-Provider: "claude" (kostenpflichtig, Cloud) oder "ollama" (kostenlos, lokal)
AI_PROVIDER=ollama

# Ollama (nur wenn AI_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Anthropic/Claude (nur wenn AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Slack-Bot (Pflicht fuer Slack-Integration)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Optional
GENESIS_API_KEY=

# Mailer (mailer/send_mails.py) — Versand der Klima-Anschreiben per Gmail-SMTP
# App-Passwort bei aktivierter 2-Faktor-Anmeldung erzeugen (16 Zeichen).
GMAIL_USER=leanstechgmbh@gmail.com
GMAIL_APP_PASSWORD=
# Absender im From-Header. Leer lassen = GMAIL_USER. Fuer Versand als info@ hier
# info@leanstech-gmbh.de eintragen (muss im Gmail-Konto als "Senden als" verifiziert sein).
MAIL_FROM=info@leanstech-gmbh.de
MAIL_ABSENDER=Semir Redzic
MAIL_FIRMA=LeansTech GmbH
MAIL_WEBSITE=www.leanstech-klima.de
